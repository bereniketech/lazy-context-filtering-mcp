{
  "name": "lazy-context-filtering-mcp",
  "version": "0.1.0",
  "description": "Hybrid TypeScript + Python MCP server for lazy context filtering.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/server/index.ts",
    "dashboard:dev": "vite --config src/dashboard/vite.config.ts",
    "dashboard:build": "vite build --config src/dashboard/vite.config.ts",
    "test": "vitest run --coverage --passWithNoTests",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.3",
    "@supabase/supabase-js": "^2.49.8",
    "crypto": "^1.0.1",
    "express": "^4.21.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.2",
    "recharts": "^3.2.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^5.0.1",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.1",
    "@types/react-dom": "^19.2.0",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^3.1.1",
    "@vitejs/plugin-react": "^5.0.4",
    "eslint": "^9.24.0",
    "jsdom": "^27.0.0",
    "supertest": "^7.1.1",
    "typescript-eslint": "^8.29.1",
    "typescript": "^5.8.3",
    "vite": "^7.1.7",
    "tsx": "^4.19.3",
    "vitest": "^3.1.1"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "mcp",
    "context-filtering",
    "typescript",
    "python"
  ],
  "license": "MIT"
}
