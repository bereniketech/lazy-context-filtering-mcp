{
  "name": "lazy-context-filtering-mcp",
  "version": "0.1.0",
  "description": "Hybrid TypeScript + Python MCP server for lazy context filtering.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/server/index.ts",
    "test": "vitest run --coverage --passWithNoTests",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.3",
    "@supabase/supabase-js": "^2.49.8",
    "crypto": "^1.0.1",
    "express": "^4.21.2",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@types/express": "^5.0.1",
    "@types/node": "^22.14.0",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^3.1.1",
    "eslint": "^9.24.0",
    "supertest": "^7.1.1",
    "typescript-eslint": "^8.29.1",
    "typescript": "^5.8.3",
    "tsx": "^4.19.3",
    "vitest": "^3.1.1"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "mcp",
    "context-filtering",
    "typescript",
    "python"
  ],
  "license": "MIT"
}
